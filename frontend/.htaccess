AuthType Basic
AuthName "Accepted Offer to Close"
AuthUserFile /home/servicedepartmen/.dealdesk_htpasswd
Require valid-user

RewriteEngine On
# DEALDESK_CLAIRE_DEALVIEW_PROXY_V1
RewriteRule ^api/claire-dealview/(.*)$ http://127.0.0.1:3022/api/claire-dealview/$1 [P,L,QSA]
RewriteRule ^api/dealdesk/claire-dealview/(.*)$ http://127.0.0.1:3022/api/claire-dealview/$1 [P,L,QSA]
# END_DEALDESK_CLAIRE_DEALVIEW_PROXY_V1
# DEALDESK_CLAIRE_READER_PROXY_V1
RewriteRule ^api/claire-reader/(.*)$ http://127.0.0.1:3021/api/claire-reader/$1 [P,L,QSA]
RewriteRule ^api/dealdesk/claire-reader/(.*)$ http://127.0.0.1:3021/api/claire-reader/$1 [P,L,QSA]
# END_DEALDESK_CLAIRE_READER_PROXY_V1
# DEALDESK_CLAIRE_DOCUMENT_REREAD_ROUTES_V1
RewriteRule ^api/intake-drafts/([^/]+)/reread-documents$ http://127.0.0.1:3017/api/intake-drafts/$1/reread-documents [P,L,QSA]
RewriteRule ^api/dealdesk/intake-drafts/([^/]+)/reread-documents$ http://127.0.0.1:3017/api/dealdesk/intake-drafts/$1/reread-documents [P,L,QSA]
# END_DEALDESK_CLAIRE_DOCUMENT_REREAD_ROUTES_V1
# DEALDESK_CLAIRE_INTAKE_ATTACHMENT_VIEW_ROUTES_V1
RewriteRule ^api/email-intake/attachments/([^/]+)/view$ http://127.0.0.1:3017/api/email-intake/attachments/$1/view [P,L,QSA]
RewriteRule ^api/dealdesk/email-intake/attachments/([^/]+)/view$ http://127.0.0.1:3017/api/dealdesk/email-intake/attachments/$1/view [P,L,QSA]
RewriteRule ^api/intake-attachments/([^/]+)/view$ http://127.0.0.1:3017/api/intake-attachments/$1/view [P,L,QSA]
RewriteRule ^api/dealdesk/intake-attachments/([^/]+)/view$ http://127.0.0.1:3017/api/dealdesk/intake-attachments/$1/view [P,L,QSA]
# END_DEALDESK_CLAIRE_INTAKE_ATTACHMENT_VIEW_ROUTES_V1
# DEALDESK_CLAIRE_EMAIL_PICKER_ROUTES_V1
RewriteRule ^api/email-intake/messages$ http://127.0.0.1:3017/api/email-intake/messages [P,L,QSA]
RewriteRule ^api/dealdesk/email-intake/messages$ http://127.0.0.1:3017/api/dealdesk/email-intake/messages [P,L,QSA]
RewriteRule ^api/email-intake/messages/([0-9]+)/import$ http://127.0.0.1:3017/api/email-intake/messages/$1/import [P,L,QSA]
RewriteRule ^api/dealdesk/email-intake/messages/([0-9]+)/import$ http://127.0.0.1:3017/api/dealdesk/email-intake/messages/$1/import [P,L,QSA]
RewriteRule ^api/email-intake/messages/([0-9]+)/skip$ http://127.0.0.1:3017/api/email-intake/messages/$1/skip [P,L,QSA]
RewriteRule ^api/dealdesk/email-intake/messages/([0-9]+)/skip$ http://127.0.0.1:3017/api/dealdesk/email-intake/messages/$1/skip [P,L,QSA]
# END_DEALDESK_CLAIRE_EMAIL_PICKER_ROUTES_V1
# DEALDESK_CLAIRE_CREATE_DEAL_DOCUMENTS_ROUTES_V1
RewriteRule ^api/intake-drafts/([^/]+)/create-deal$ http://127.0.0.1:3017/api/intake-drafts/$1/create-deal [P,L,QSA]
RewriteRule ^api/dealdesk/intake-drafts/([^/]+)/create-deal$ http://127.0.0.1:3017/api/dealdesk/intake-drafts/$1/create-deal [P,L,QSA]
RewriteRule ^api/deals/([^/]+)/documents$ http://127.0.0.1:3017/api/deals/$1/documents [P,L,QSA]
RewriteRule ^api/dealdesk/deals/([^/]+)/documents$ http://127.0.0.1:3017/api/dealdesk/deals/$1/documents [P,L,QSA]
RewriteRule ^api/deal-documents/([^/]+)/view$ http://127.0.0.1:3017/api/deal-documents/$1/view [P,L,QSA]
RewriteRule ^api/dealdesk/deal-documents/([^/]+)/view$ http://127.0.0.1:3017/api/dealdesk/deal-documents/$1/view [P,L,QSA]
# END_DEALDESK_CLAIRE_CREATE_DEAL_DOCUMENTS_ROUTES_V1
# DEALDESK_CLAIRE_EMAIL_TO_INTAKE_ROUTES_V1
RewriteRule ^api/intake-drafts$ http://127.0.0.1:3017/api/intake-drafts [P,L,QSA]
RewriteRule ^api/dealdesk/intake-drafts$ http://127.0.0.1:3017/api/dealdesk/intake-drafts [P,L,QSA]
RewriteRule ^api/intake-drafts/([^/]+)$ http://127.0.0.1:3017/api/intake-drafts/$1 [P,L,QSA]
RewriteRule ^api/dealdesk/intake-drafts/([^/]+)$ http://127.0.0.1:3017/api/dealdesk/intake-drafts/$1 [P,L,QSA]
RewriteRule ^api/intake-drafts/([^/]+)/status$ http://127.0.0.1:3017/api/intake-drafts/$1/status [P,L,QSA]
RewriteRule ^api/dealdesk/intake-drafts/([^/]+)/status$ http://127.0.0.1:3017/api/dealdesk/intake-drafts/$1/status [P,L,QSA]
RewriteRule ^api/intake-drafts/([^/]+)/reject$ http://127.0.0.1:3017/api/intake-drafts/$1/reject [P,L,QSA]
RewriteRule ^api/dealdesk/intake-drafts/([^/]+)/reject$ http://127.0.0.1:3017/api/dealdesk/intake-drafts/$1/reject [P,L,QSA]
# END_DEALDESK_CLAIRE_EMAIL_TO_INTAKE_ROUTES_V1
# DEALDESK_CLEARANCE_EMAIL_DRAFT_ROUTES_V1
RewriteRule ^api/deals/([^/]+)/clearance-draft-email$ http://127.0.0.1:3017/api/deals/$1/clearance-draft-email [P,L,QSA]
RewriteRule ^api/dealdesk/deals/([^/]+)/clearance-draft-email$ http://127.0.0.1:3017/api/dealdesk/deals/$1/clearance-draft-email [P,L,QSA]
RewriteRule ^api/deals/([^/]+)/clearance-controls/([^/]+)/draft-email$ http://127.0.0.1:3017/api/deals/$1/clearance-controls/$2/draft-email [P,L,QSA]
RewriteRule ^api/dealdesk/deals/([^/]+)/clearance-controls/([^/]+)/draft-email$ http://127.0.0.1:3017/api/dealdesk/deals/$1/clearance-controls/$2/draft-email [P,L,QSA]
# END_DEALDESK_CLEARANCE_EMAIL_DRAFT_ROUTES_V1
RewriteRule ^api/deals/([^/]+)/clearance-controls$ http://127.0.0.1:3017/api/dealdesk/deals/$1/clearance-controls [P,L]
RewriteRule ^api/deals/([^/]+)/clearance-controls/([^/]+)$ http://127.0.0.1:3017/api/dealdesk/deals/$1/clearance-controls/$2 [P,L]

RewriteRule ^api/health$ http://127.0.0.1:3017/api/dealdesk/health [P,L]
RewriteRule ^api/manager-chat-smart$ http://127.0.0.1:3017/api/dealdesk/manager-chat-smart [P,L]
RewriteRule ^api/manager-chat$ http://127.0.0.1:3017/api/dealdesk/manager-chat [P,L]
RewriteRule ^api/dashboard$ http://127.0.0.1:3017/api/dealdesk/dashboard [P,L]
RewriteRule ^api/directory$ http://127.0.0.1:3017/api/dealdesk/directory [P,L]
RewriteRule ^api/deals$ http://127.0.0.1:3017/api/dealdesk/deals [P,L]
RewriteRule ^api/deals/([0-9a-fA-F-]{36})/communications$ http://127.0.0.1:3017/api/dealdesk/deals/$1/communications [P,L]
RewriteRule ^api/deals/([0-9a-fA-F-]{36})/build-plan$ http://127.0.0.1:3017/api/dealdesk/deals/$1/build-plan [P,L]
RewriteRule ^api/deals/([0-9a-fA-F-]{36})/status$ http://127.0.0.1:3017/api/dealdesk/deals/$1/status [P,L]
RewriteRule ^api/deals/([0-9a-fA-F-]{36})/start-emails$ http://127.0.0.1:3017/api/dealdesk/deals/$1/start-emails [P,L]
RewriteRule ^api/emails/([0-9a-fA-F-]{36})/send$ http://127.0.0.1:3017/api/dealdesk/emails/$1/send [P,L]
RewriteRule ^api/deals/([0-9a-fA-F-]{36})/tracker/([0-9a-fA-F-]{36})/update$ http://127.0.0.1:3017/api/dealdesk/deals/$1/tracker/$2/update [P,L]
RewriteRule ^api/deals/([0-9a-fA-F-]{36})/tracker$ http://127.0.0.1:3017/api/dealdesk/deals/$1/tracker [P,L]
RewriteRule ^api/deals/([0-9a-fA-F-]{36})/ai-review$ http://127.0.0.1:3017/api/dealdesk/deals/$1/ai-review [P,L]
RewriteRule ^api/deals/([0-9a-fA-F-]{36})$ http://127.0.0.1:3017/api/dealdesk/deals/$1 [P,L]
